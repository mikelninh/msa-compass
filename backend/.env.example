# Copy this to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.
# Railway sets DATABASE_URL automatically when you add a PostgreSQL plugin.
# Supabase shows DATABASE_URL in: Project Settings → Database → Connection string

DATABASE_URL=postgresql://postgres:yourpassword@db.supabase.co:5432/postgres

# Generate a strong random key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RESEARCHER_API_KEY=replace-with-a-long-random-secret-key

NODE_ENV=production
